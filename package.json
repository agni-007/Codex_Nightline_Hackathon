{
  "name": "hyperlocal-echo",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first CLI content orchestration engine for small local businesses.",
  "type": "module",
  "bin": {
    "hyperlocal-echo": "./src/cli.ts"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--use-system-ca tsx src/cli.ts",
    "dev": "cross-env NODE_OPTIONS=--use-system-ca tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "openai": "^6.16.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.5",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9"
  }
}
